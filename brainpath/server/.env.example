# Copy this file to .env and fill in real values. Never commit .env itself.

# Get this from Supabase: Project Settings -> Database -> Connection string (URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

PORT=5000
NODE_ENV=development

# Add these as you build auth:
# JWT_SECRET=
# JWT_REFRESH_SECRET=

# Add these as you wire up Cloudinary:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
